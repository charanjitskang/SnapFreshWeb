{
  "name": "snapfresh-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:seo": "node ./scripts/generate-seo-assets.mjs",
    "build:ssr": "vite build --ssr ./src/entries/ssr.tsx --outDir .ssr",
    "prerender:dist": "npm run build:ssr && node ./scripts/prerender-dist.mjs",
    "dev": "vite",
    "prebuild": "npm run generate:seo",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build && npm run prerender:dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.9"
  }
}
